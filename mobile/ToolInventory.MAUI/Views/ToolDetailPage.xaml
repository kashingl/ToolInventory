<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToolInventory.MAUI.ViewModels"
             x:Class="ToolInventory.MAUI.Views.ToolDetailPage"
             x:DataType="vm:ToolDetailViewModel"
             Title="{Binding Tool.Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Delete" Command="{Binding DeleteCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="12" IsVisible="{Binding Tool, Converter={StaticResource NotNullConverter}}">
            <Border Style="{StaticResource AppCardBorderStyle}" Margin="0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="12">
                    <Label Grid.Row="0" Grid.Column="0" Text="Status" FontAttributes="Bold" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding Tool.Status}"
                           LineBreakMode="WordWrap"
                           TextColor="{Binding Tool.Status, Converter={StaticResource StatusColorConverter}}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Category" FontAttributes="Bold" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Tool.CategoryName}" LineBreakMode="WordWrap" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Location" FontAttributes="Bold" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding Tool.Location}" LineBreakMode="WordWrap" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Systainer" FontAttributes="Bold" />
                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding Tool.Systainer}" LineBreakMode="WordWrap" />

                    <Label Grid.Row="4" Grid.Column="0" Text="Barcode" FontAttributes="Bold" />
                    <Label Grid.Row="4" Grid.Column="1" Text="{Binding Tool.Barcode}" LineBreakMode="WordWrap" />

                    <Label Grid.Row="5" Grid.Column="0" Text="Description" FontAttributes="Bold" />
                    <Label Grid.Row="5" Grid.Column="1" Text="{Binding Tool.Description}" LineBreakMode="WordWrap" />
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
