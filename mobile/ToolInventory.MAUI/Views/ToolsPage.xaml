<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToolInventory.MAUI.ViewModels"
             xmlns:dto="clr-namespace:ToolInventory.Shared.DTOs;assembly=ToolInventory.Shared"
             x:Class="ToolInventory.MAUI.Views.ToolsPage"
             x:DataType="vm:ToolsViewModel"
             Title="Tools">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Scan" Command="{Binding OpenScannerCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <SearchBar Grid.Row="0" Placeholder="Search tools..." Text="{Binding SearchText}" Margin="8" />

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView x:Name="ToolsCollectionView"
                            ItemsSource="{Binding Tools}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ToolDto">
                        <Border Margin="8,4" Padding="12" StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Status}"
                                       TextColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                       FontSize="12"
                                       VerticalOptions="Center" />
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="13" TextColor="Gray">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Location}" />
                                            <Span Text=" · Systainer: " />
                                            <Span Text="{Binding Systainer}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
