<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToolInventory.MAUI.ViewModels"
             xmlns:dto="clr-namespace:ToolInventory.Shared.DTOs;assembly=ToolInventory.Shared"
             x:Class="ToolInventory.MAUI.Views.ToolsPage"
             x:DataType="vm:ToolsViewModel"
             Title="Tools">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Scan" Command="{Binding OpenScannerCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="10,10,10,0">
        <Border Grid.Row="0" Style="{StaticResource AppCardBorderStyle}" Padding="6,2">
            <SearchBar Placeholder="Search tools..." Text="{Binding SearchText}" />
        </Border>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView x:Name="ToolsCollectionView"
                            ItemsSource="{Binding Tools}"
                            ItemSizingStrategy="MeasureAllItems"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ToolDto">
                        <Border Style="{StaticResource AppCardBorderStyle}">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Name}"
                                       Style="{StaticResource CardTitleLabel}" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Status}"
                                       TextColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                       LineBreakMode="WordWrap"
                                       FontSize="12"
                                       VerticalOptions="Center" />
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource MutedMetaLabel}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Location}" />
                                            <Span Text=" · Systainer: " />
                                            <Span Text="{Binding Systainer}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
