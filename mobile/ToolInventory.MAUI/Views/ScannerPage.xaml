<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToolInventory.MAUI.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="ToolInventory.MAUI.Views.ScannerPage"
             x:DataType="vm:ScannerViewModel"
             Title="Scanner">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceAlt}">
        <zxing:CameraBarcodeReaderView Grid.Row="0"
                                       x:Name="BarcodeReader"
                                       BarcodesDetected="OnBarcodesDetected"
                                       IsVisible="{Binding IsScanning}" />

        <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="12">
            <Label Text="{Binding StatusMessage}"
                   HorizontalOptions="Center"
                   FontSize="14"
                   TextColor="{StaticResource Gray600}"
                   LineBreakMode="WordWrap"
                   HorizontalTextAlignment="Center" />

            <Border Style="{StaticResource AppCardBorderStyle}" Margin="0"
                    IsVisible="{Binding FoundTool, Converter={StaticResource NotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding FoundTool.Name}" Style="{StaticResource CardTitleLabel}" />
                    <Label Text="{Binding FoundTool.Status}"
                           LineBreakMode="WordWrap"
                           TextColor="{Binding FoundTool.Status, Converter={StaticResource StatusColorConverter}}" />
                    <Label LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Make/Model: " FontAttributes="Bold" />
                                <Span Text="{Binding FoundTool.Make}" />
                                <Span Text=" " />
                                <Span Text="{Binding FoundTool.Model}" />
                                <Span Text=" · SN: " FontAttributes="Bold" />
                                <Span Text="{Binding FoundTool.SerialNumber}" />
                                <Span Text=" · Owner: " FontAttributes="Bold" />
                                <Span Text="{Binding FoundTool.Owner}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Location: " FontAttributes="Bold" />
                                <Span Text="{Binding FoundTool.Location}" />
                                <Span Text=" · Systainer: " FontAttributes="Bold" />
                                <Span Text="{Binding FoundTool.Systainer}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <FlexLayout Direction="Row" Wrap="Wrap" JustifyContent="Center" AlignItems="Center">
                        <Button Text="Check Out"
                                Command="{Binding CheckOutCommand}"
                                IsVisible="{Binding FoundTool.Status, Converter={StaticResource StatusEqualsConverter}, ConverterParameter=Available}" />
                        <Button Text="Check In"
                                Command="{Binding CheckInCommand}"
                                IsVisible="{Binding FoundTool.Status, Converter={StaticResource StatusEqualsConverter}, ConverterParameter=CheckedOut}" />
                        <Button Text="Scan Again" Command="{Binding ScanAgainCommand}" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
