<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToolInventory.MAUI.ViewModels"
             xmlns:dto="clr-namespace:ToolInventory.Shared.DTOs;assembly=ToolInventory.Shared"
             x:Class="ToolInventory.MAUI.Views.CheckoutsPage"
             x:Name="Page"
             x:DataType="vm:CheckoutsViewModel"
             Title="Check-in / Out">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Check Out" Command="{Binding CheckOutToolCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <CollectionView ItemsSource="{Binding Checkouts}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:CheckoutDto">
                    <Border Margin="8,4" Padding="12" StrokeShape="RoundRectangle 8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding ToolName}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding UserName}" FontSize="13" TextColor="Gray" />
                            <Label Grid.Row="2" Grid.Column="0" Text="{Binding CheckoutDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="12" TextColor="Gray" />
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                    Text="Check In"
                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.CheckInCommand}"
                                    CommandParameter="{Binding .}"
                                    IsVisible="{Binding ActualReturnDate, Converter={StaticResource NullToBoolConverter}}"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
