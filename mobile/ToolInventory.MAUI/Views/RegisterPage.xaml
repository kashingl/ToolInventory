<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToolInventory.MAUI.Views.RegisterPage"
             Title="Register">
    <Grid Padding="24">
        <Border Style="{StaticResource AppCardBorderStyle}" Margin="0" Padding="18">
            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Register" Style="{StaticResource PageTitleLabel}" />
                <Label Text="De registratieflow voor mobiel volgt in de volgende iteratie."
                       Style="{StaticResource MutedMetaLabel}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
